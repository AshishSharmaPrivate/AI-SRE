import json
import boto3
import os

sns = boto3.client("sns")
bedrock = boto3.client("bedrock-runtime")

MODEL_ID = "amazon.nova-lite-v1:0"

def generate_ai_rca():

    response = bedrock.converse(
        modelId=MODEL_ID,
        messages=[
            {
                "role": "user",
                "content": [
                    {
                        "text": """
CloudWatch Alarm Triggered: EC2 High CPU > 70%.

Create a professional SRE Incident Report with:
1. Incident Summary
2. Root Cause
3. Customer Impact
4. Immediate Fix
5. Prevention Steps
"""
                    }
                ],
            }
        ],
        inferenceConfig={
            "maxTokens": 400,
            "temperature": 0.3
        },
    )

    return response["output"]["message"]["content"][0]["text"]


def lambda_handler(event, context):
    print("Generating AI RCA via Nova...")

    report = generate_ai_rca()

    sns.publish(
        TopicArn=os.environ["SNS_TOPIC_ARN"],
        Subject="AI SRE Incident Report",
        Message=report
    )

    return {"status": "SUCCESS"}


